<usx version="3.1">
  <book code="DAN" style="id">dan PT_APBRT pt_Portuguese_ltr</book>
  <para style="h">Daniel
</para>
  <para style="toc1">Daniel
</para>
  <para style="toc2">Daniel
</para>
